{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    "paths": {
      "@/*": ["./*"],
      "@src/*": ["./src/*"],
      "@features/*": ["./src/features/*"],
      "@hooks/*": ["./src/features/*/hooks"],
      "@store/*": ["./src/store/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
